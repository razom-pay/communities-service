generator client {
  provider = "prisma-client"
  output = "./generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum CommunityVisibility {
  PUBLIC
  PRIVATE

  @@map("community_visibility")
}

enum CommunityRole {
  OWNER
  MODERATOR
  MEMBER

  @@map("community_role")
}

enum CommunityInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED

  @@map("community_invite_status")
}

enum InitiativeType {
  CROWDFUNDING
  WHOLESALE

  @@map("initiative_type")
}

enum InitiativeStatus {
  ACTIVE
  SETTLING
  SUCCEEDED
  FAILED
  CANCELED

  @@map("initiative_status")
}

enum InitiativeContributionRuleType {
  ANY
  MIN_ONLY
  FIXED
  RANGE

  @@map("initiative_contribution_rule_type")
}

enum InitiativeContributionStatus {
  HELD
  CAPTURED
  REFUNDED
  PARTIALLY_REFUNDED

  @@map("initiative_contribution_status")
}

enum InitiativeSettlementOutcome {
  SUCCESS
  FAILED
  CANCELED

  @@map("initiative_settlement_outcome")
}

model Community {
  id String @id @default(nanoid())

  description String
  visibility CommunityVisibility @default(PUBLIC)

  locationCountry String? @map("location_country")
  locationCity String? @map("location_city")
  locationStreet String? @map("location_street")
  locationHouse String? @map("location_house")

  avatar String?
  cover String?

  membersCount Int @default(1) @map("members_count")
  createdByUserId String @map("created_by_user_id")

  memberships CommunityMembership[]
  invites CommunityInvite[]
  bans CommunityBan[]
  initiatives CommunityInitiative[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("communities")
}

model CommunityMembership {
  id String @id @default(nanoid())

  communityId String @map("community_id")
  userId String @map("user_id")
  role CommunityRole @default(MEMBER)

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([communityId, userId])
  @@index([userId])
  @@map("community_memberships")
}

model CommunityInvite {
  id String @id @default(nanoid())

  communityId String @map("community_id")
  invitedUserId String @map("invited_user_id")
  invitedByUserId String @map("invited_by_user_id")
  status CommunityInviteStatus @default(PENDING)
  expiresAt DateTime @map("expires_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([communityId, invitedUserId])
  @@index([status, expiresAt])
  @@map("community_invites")
}

model CommunityBan {
  id String @id @default(nanoid())

  communityId String @map("community_id")
  userId String @map("user_id")
  bannedByUserId String @map("banned_by_user_id")

  reason String?
  expiresAt DateTime? @map("expires_at")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([communityId, userId])
  @@index([expiresAt])
  @@map("community_bans")
}

model CommunityInitiative {
  id String @id @default(nanoid())

  communityId String @map("community_id")
  organizerUserId String @map("organizer_user_id")

  type InitiativeType
  status InitiativeStatus @default(ACTIVE)

  title String
  description String
  currency String @default("UAH")

  organizerFeeMinor BigInt @map("organizer_fee_minor")
  goalAmountMinor BigInt? @map("goal_amount_minor")

  crowdfundingRuleType InitiativeContributionRuleType? @map("crowdfunding_rule_type")
  crowdfundingMinAmountMinor BigInt? @map("crowdfunding_min_amount_minor")
  crowdfundingFixedAmountMinor BigInt? @map("crowdfunding_fixed_amount_minor")
  crowdfundingMaxAmountMinor BigInt? @map("crowdfunding_max_amount_minor")

  minSuccessUnits Int? @map("min_success_units")
  maxUnits Int? @map("max_units")

  collectedAmountMinor BigInt @default(0) @map("collected_amount_minor")
  collectedUnits Int @default(0) @map("collected_units")

  deadlineAt DateTime @map("deadline_at")
  settlementOutcome InitiativeSettlementOutcome? @map("settlement_outcome")

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  wholesaleTiers CommunityInitiativeWholesaleTier[]
  contributions CommunityInitiativeContribution[]
  settlement CommunityInitiativeSettlement?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([communityId, status, deadlineAt])
  @@index([organizerUserId, createdAt])
  @@map("community_initiatives")
}

model CommunityInitiativeWholesaleTier {
  id String @id @default(nanoid())

  initiativeId String @map("initiative_id")
  minUnits Int @map("min_units")
  unitPriceMinor BigInt @map("unit_price_minor")

  initiative CommunityInitiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([initiativeId, minUnits])
  @@index([initiativeId, minUnits])
  @@map("community_initiative_wholesale_tiers")
}

model CommunityInitiativeContribution {
  id String @id @default(nanoid())

  initiativeId String @map("initiative_id")
  contributorUserId String @map("contributor_user_id")
  requestId String @map("request_id")

  amountMinor BigInt @map("amount_minor")
  units Int @default(0)

  status InitiativeContributionStatus @default(HELD)
  capturedAmountMinor BigInt @default(0) @map("captured_amount_minor")
  refundedAmountMinor BigInt @default(0) @map("refunded_amount_minor")

  initiative CommunityInitiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([initiativeId, requestId])
  @@index([initiativeId, contributorUserId])
  @@index([initiativeId, createdAt, id])
  @@map("community_initiative_contributions")
}

model CommunityInitiativeSettlement {
  id String @id @default(nanoid())

  initiativeId String @unique @map("initiative_id")
  outcome InitiativeSettlementOutcome

  totalHeldMinor BigInt @map("total_held_minor")
  totalCapturedMinor BigInt @map("total_captured_minor")
  totalRefundedMinor BigInt @map("total_refunded_minor")
  finalUnitPriceMinor BigInt? @map("final_unit_price_minor")

  initiative CommunityInitiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("community_initiative_settlements")
}
